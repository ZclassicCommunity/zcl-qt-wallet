        <widget class="QCheckBox" name="chkDataChannel">
         <property name="text">
          <string>Enable private file transfers (encrypted file content)</string>
         </property>
        </widget>
       </item>
       <item row="18" column="0" colspan="2">
        <widget class="QLabel" name="label_datachannel">
         <property name="text">
          <string>Lets you send and receive files whose contents are private (encrypted). It does NOT make collectible ownership private — who holds a token is always public — and the encrypted file is stored on every node permanently and can never be deleted. Restart to apply. Default: off.</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
